{
  "format": "api-workbench-collection",
  "schemaVersion": 1,
  "collection": {
    "id": "col-awb-local-httpbin",
    "name": "AWB Local HTTPBin",
    "description": "Deterministic local smoke collection for API Workbench manual QA.",
    "format": "api-workbench",
    "version": "1.0.0",
    "requests": [
      {
        "id": "req-awb-oauth-protected",
        "name": "AWB OAuth Protected Resource",
        "path": "OAuth",
        "sourceCollection": "AWB Local HTTPBin",
        "method": "GET",
        "url": "{{oauth_protected_url}}",
        "authOverrideMode": "explicit",
        "auth": {
          "type": "oauth2",
          "properties": {
            "grantType": "client_credentials",
            "accessTokenUrl": "{{oauth_token_url}}",
            "clientId": "{{oauth_client_id}}",
            "clientSecret": "{{oauth_client_secret}}",
            "scope": "{{oauth_scope}}",
            "accessToken": "{{oauth2_access_token}}"
          }
        },
        "explicitAuth": {
          "type": "oauth2",
          "properties": {
            "grantType": "client_credentials",
            "accessTokenUrl": "{{oauth_token_url}}",
            "clientId": "{{oauth_client_id}}",
            "clientSecret": "{{oauth_client_secret}}",
            "scope": "{{oauth_scope}}",
            "accessToken": "{{oauth2_access_token}}"
          }
        },
        "headers": [
          {"key": "Accept", "value": "application/json"}
        ],
        "body": {"mode": "none"}
      }
    ],
    "folderPaths": ["OAuth"]
  }
}
